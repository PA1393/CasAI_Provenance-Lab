# Backend environment variables.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Never commit the real .env or paste secrets into source code.

# Supabase project — service role key is backend-only, never expose to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OpenAI — used for RAG query embeddings and answer generation.
# Get a key at https://platform.openai.com/api-keys (billing must be enabled).
OPENAI_API_KEY=sk-your-openai-key

# Optional: override the chat model used for answer generation (defaults to gpt-4o-mini).
# OPENAI_CHAT_MODEL=gpt-4o-mini
